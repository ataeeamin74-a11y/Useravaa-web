{
  "experienceTimelineForm": {
    "timelineItems": {
      "required": true,
      "type": "array",
      "minItems": 1,
      "errorKey": "timeline.required"
    },
    "jobTitle": {
      "required": true,
      "type": "string",
      "minLength": 2,
      "maxLength": 100,
      "errorKey": "timeline.jobTitle.invalid"
    },
    "orgLevel": {
      "required": true,
      "type": "enum",
      "allowedValues": [
        "کارآموز",
        "کارشناس",
        "کارشناس ارشد",
        "مدیر میانی",
        "مدیر ارشد",
        "معاونت",
        "مدیر کسب و کار"
      ],
      "errorKey": "timeline.orgLevel.invalid"
    },
    "companyName": {
      "required": true,
      "type": "string",
      "minLength": 2,
      "maxLength": 120,
      "errorKey": "timeline.companyName.invalid"
    },
    "companyField": {
      "required": true,
      "type": "string",
      "minLength": 2,
      "maxLength": 80,
      "errorKey": "timeline.companyField.invalid"
    },
    "companyCountry": {
      "required": true,
      "type": "string",
      "errorKey": "timeline.companyCountry.required"
    },
    "startYear": {
      "required": true,
      "type": "integer",
      "errorKey": "timeline.startYear.required"
    },
    "endYear": {
      "required": "if isCurrent=false",
      "type": "integer",
      "errorKey": "timeline.endYear.required"
    },
    "dateRange": {
      "required": true,
      "rule": "end date must be after start date",
      "errorKey": "timeline.dateRange.invalid"
    },
    "fiveYearCoverage": {
      "required": "warning_or_blocking_decision",
      "rule": "if total years of experience >= 5, timeline should cover last five years",
      "warningKey": "timeline.fiveYearCoverage.warning"
    }
  }
}
