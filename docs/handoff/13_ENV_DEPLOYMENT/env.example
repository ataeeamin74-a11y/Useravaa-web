# Runtime
NODE_ENV=development
APP_ENV=development
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000/api
USERAVAA_SITE_INDEXING=0
USERAVAA_ENABLE_HSTS=0

# Database
# Direct PostgreSQL runtime uses @prisma/adapter-pg.
# Use a non-production database for local smoke tests.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
PRISMA_ACCELERATE_URL=
USERAVAA_DB_SMOKE_TEST=0

# Authentication
AUTH_SECRET=
JWT_SECRET=
USERAVAA_ENABLE_DEV_AUTH=0
USERAVAA_ENABLE_ADMIN_DEMO_FALLBACK=0

# Staging access bootstrap planning
# Placeholders only. Real operator identifiers belong in the deployment env store or secret manager.
STAGING_PRIMARY_ADMIN_EMAIL=
STAGING_SUPPORT_EMAIL=
USERAVAA_ENABLE_STAGING_ACCESS=0
USERAVAA_STAGING_ACCESS_HEADER=
USERAVAA_STAGING_ACCESS_IDENTITY_HEADER=
USERAVAA_STAGING_ACCESS_SECRET=
USERAVAA_STAGING_BOOTSTRAP_DRY_RUN=1
USERAVAA_ALLOW_STAGING_BOOTSTRAP=0

# File upload / object storage
UPLOAD_STORAGE_PROVIDER=
UPLOAD_BUCKET=
UPLOAD_MAX_AVATAR_BYTES=2097152

# Payment / wallet
PAYMENT_PROVIDER=
PAYMENT_CALLBACK_URL=
PAYMENT_WEBHOOK_SECRET=

# Notification
NOTIFICATION_PROVIDER=
EMAIL_PROVIDER=
SMS_PROVIDER=

# Monitoring
LOG_LEVEL=info
SENTRY_DSN=
