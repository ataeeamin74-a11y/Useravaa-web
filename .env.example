# Runtime
NODE_ENV=development
APP_ENV=development
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000/api
# Safe default: staging/internal builds are noindex unless production explicitly opts in.
USERAVAA_SITE_INDEXING=0
# Enable only for confirmed HTTPS production deployments.
USERAVAA_ENABLE_HSTS=0

# Database
# Direct PostgreSQL runtime uses @prisma/adapter-pg.
# Use a non-production database for local smoke tests.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Optional Prisma Accelerate runtime. If set, it takes precedence over DATABASE_URL.
PRISMA_ACCELERATE_URL=
# Set to 1 only when DATABASE_URL/PRISMA_ACCELERATE_URL points at a safe non-production DB.
USERAVAA_DB_SMOKE_TEST=0

# Authentication
AUTH_SECRET=
JWT_SECRET=
# Local/dev-only fixture auth helper. Ignored in production even if set.
USERAVAA_ENABLE_DEV_AUTH=0
# Local/dev-only admin demo fallback helper. Ignored in production even if set.
USERAVAA_ENABLE_ADMIN_DEMO_FALLBACK=0

# File upload / object storage
UPLOAD_STORAGE_PROVIDER=
UPLOAD_BUCKET=
UPLOAD_MAX_AVATAR_BYTES=2097152

# Payment / wallet
PAYMENT_PROVIDER=
PAYMENT_CALLBACK_URL=
PAYMENT_WEBHOOK_SECRET=

# Notification
NOTIFICATION_PROVIDER=
EMAIL_PROVIDER=
SMS_PROVIDER=

# Monitoring
LOG_LEVEL=info
SENTRY_DSN=
